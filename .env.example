# ─── LLM Provider API Keys ───
# At least one provider is required. Uncomment and fill in the ones you use.

# OpenRouter (recommended for OSS models)
# OPENROUTER_API_KEY=sk-or-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast inference for OSS models)
# GROQ_API_KEY=gsk_...

# ─── Local Models ───
# Ollama (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Ultron Config ───
# ULTRON_LOG_LEVEL=INFO
# ULTRON_DATA_DIR=./data
